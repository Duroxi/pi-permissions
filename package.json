{
  "name": "pi-permissions",
  "version": "0.1.0",
  "description": "Permission enforcement extension for the Pi coding agent. Forked from gotgenes/pi-permission-system.",
  "type": "module",
  "exports": {
    ".": "./src/service.ts"
  },
  "imports": {
    "#src/*": "./src/*",
    "#test/*": "./test/*"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:md": "rumdl check *.md docs/**/*.md",
    "lint": "biome check . && eslint . && pnpm run lint:md"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "pi-coding-agent",
    "coding-agent",
    "permissions",
    "policy",
    "access-control",
    "authorization",
    "security"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.79.0",
    "@earendil-works/pi-tui": ">=0.79.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@earendil-works/pi-coding-agent": "0.79.1",
    "@earendil-works/pi-tui": "0.79.1",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "tree-sitter-bash": "^0.25.1",
    "web-tree-sitter": "^0.26.9"
  }
}
